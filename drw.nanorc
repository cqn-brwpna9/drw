# Syntax highlighting for drw

syntax drw "\.drw(m)?"
comment "#"
tabgives "  "

# This is HEAVLY based off of uiua formatting/highliting

# Numbers
color orange "[0-9]"

# Nilads
color brightred "[ordu?e,]"

# Monads
color brightgreen "[\^~cs.!()UqSCfRI;]"

# Dyads
color brightblue "(:|\+|\-|\*|\/|\%|P|l|<|>|=)"

# Triads
color cyan "[B@&]"

# Loops
color brightyellow "(\[|\]|\{|\})"

# Function binding
color purple "_"

# Comments
color grey "#.*"
